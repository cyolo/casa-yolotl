{
  "name": "casa-yolotl-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx concurrently \"npm run dev --workspace=casa-yolotl\" \"npm run dev --workspace=casa-yolotl-admin\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "ci-verify": "node scripts/lh-check.js"
  }
}